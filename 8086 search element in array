                OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
ARRAY DW 0000H,0001H,0004H,0003H,0002H
COUNT EQU 0005H
KEY DW 0002H
RESULT DB 00H
DATA ENDS
CODE SEGMENT
        ASSUME CS:CODE,DS:DATA
        MOV AX,DATA
        MOV DS,AX
        MOV DX,COUNT
        MOV SI,OFFSET ARRAY
        MOV RESULT,00H
L1:     MOV AX,[SI]
        CMP AX,KEY
        JC L2
        INC SI
        INC SI
        LOOP L1
        MOV RESULT,00H
        JMP L3
L2:     MOV RESULT,01H
L3:     HLT
CODE ENDS
END
