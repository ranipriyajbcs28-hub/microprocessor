                OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
ARRAY DB 00H, 05H, 06H, 03H, 01H
RESARRAY DB 00H, 00H, 00H, 00H, 00H
COUNT EQU 05H
DATA ENDS
CODE SEGMENT
        ASSUME CS:CODE,DS:DATA
        MOV AX,DATA
        MOV DS,AX
        MOV DX,COUNT
        LEA SI,ARRAY
L1:     MOV AX,5[SI]
        MOV BX,AX
        DEC SI
        DEC DX
        MOV RESARRAY,BX
        JNZ L1
        JMP L3
L3:     HLT
CODE ENDS
END
